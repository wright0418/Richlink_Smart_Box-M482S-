{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMSIS_DAP@pyOCD (launch)",
            "type": "cortex-debug-nuvoton",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMSIS Build (CLI ARMCLANG)",
            "executable": "${workspaceFolder}/out/RL_SPORT/ARMCLANG/debug/RL_SPORT.axf",
            "servertype": "openocd",
            "serverpath": "${command:openocd-helper.getOpenOcdPath}",
            "svdFile": "${command:openocd-helper.getSvdPath}",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "${command:openocd-helper.getOpenOcdConfigPath}"
            ],
            "runToEntryPoint": "main",
            "overrideLaunchCommands": [
                "monitor reset halt"
            ]
        }
    ]
}